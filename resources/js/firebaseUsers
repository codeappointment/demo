import { initializeApp } from "firebase/app";
import { getAuth, onAuthStateChanged } from "firebase/auth";
import firebase from "firebase/compat/app";
import "firebase/firestore";
import { getFirestore, collection, addDoc, setDoc, doc, updateDoc, getDoc } from "firebase/firestore";

import { app } from './firebaseAuth.js';
import { signInWithGoogle } from './signin.js';


const auth = getAuth(app);
const db = getFirestore(app)
let docRef;
let userID;
let userDataExists = false;
const confirmBtn = document.getElementById('confirmBtn');

onAuthStateChanged(auth, (user) => {
    if (user) {
        // User is signed in, see docs for a list of available properties
        // https://firebase.google.com/docs/reference/js/auth.user
        const uid = user.uid;
        const doctorName = document.getElementById('doctorName')
        // doctorName.innerText = user.displayName;
        userID = auth.currentUser.email
        docRef = doc(db, "users", userID);
        getUserDocument(userID);

        // ...
    } else {
        // User is signed out
        signInWithGoogle();
    }
});


async function getUserDocument(userID) {
    // 1. Create a reference to the specific document
    const docRef = doc(db, "users", userID);

    try {
        // 2. Fetch the document snapshot
        const documentSnapshot = await getDoc(docRef);

        // 3. Check if the document exists before reading it
        if (documentSnapshot.exists()) {
            userDataExists = true;
            // console.log("Document data:", documentSnapshot.data());

            // Accessing specific fields:
            const userData = documentSnapshot.data();
            const name = userData.name;
            doctorName.innerText = name
            // console.log("First Name:", userData.name);
        } else {
            userDataExists = false;
            // docSnap.data() will be undefined here
            console.log("No such document found!");
        }
    } catch (error) {
        console.error("Error fetching document:", error);
    }
}
